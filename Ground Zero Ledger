from dataclasses import dataclass
from typing import Dict, List, Optional, Set
from datetime import datetime
import hashlib
import uuid
from enum import Enum

class ForkStatus(Enum):
    """Status of the Ethereum fork"""
    PROPOSAL = "proposal"
    ACTIVE = "active"
    SUSPENDED = "suspended"
    DEPRECATED = "deprecated"

class ConsensusType(Enum):
    """Consensus mechanism types"""
    POW = "proof_of_work"
    POS = "proof_of_stake"
    PBS = "proof_of_stake_better"

class GroundZeroFork:
    """Represents the Ground Zero Ethereum fork"""
    
    def __init__(self, name: str = "Ground Zero", description: str = "Ethereum fork with improved consensus"):
        self.fork_id = str(uuid.uuid4())
        self.name = name
        self.description = description
        self.status = ForkStatus.PROPOSAL
        self.created_at = datetime.now()
        self.updated_at = datetime.now()
        self.blockchain_data: Dict = {}
        self.consensus_type = ConsensusType.POS
        self.network_params: Dict = {
            "block_time": 12,  # seconds
            "gas_limit": 30_000_000,
            "base_fee_per_gas": 1000000000,  # 1 Gwei
            "hardforks": []
        }
        self.developers: Set[str] = set()
        self.sponsors: List[str] = []
        self.benefits: List[str] = [
            "Improved scalability",
            "Enhanced security",
            "Better energy efficiency",
            "Reduced transaction costs"
        ]
        self.risks: List[str] = [
            "Network split risk",
            "Adoption challenges",
            "Security vulnerabilities"
        ]
        self.community: Dict = {
            "active_users": 0,
            "discussions": [],
            "supporters": []
        }

    def set_consensus(self, consensus_type: ConsensusType):
        """Set the consensus mechanism"""
        self.consensus_type = consensus_type
        self.updated_at = datetime.now()

    def add_developer(self, developer_name: str):
        """Add a developer to the fork"""
        self.developers.add(developer_name)
        self.updated_at = datetime.now()

    def add_sponsor(self, sponsor_name: str):
        """Add a sponsor"""
        self.sponsors.append(sponsor_name)
        self.updated_at = datetime.now()

    def add_hardfork(self, hardfork_name: str, block_number: int):
        """Add a hardfork to the network"""
        self.network_params["hardforks"].append({
            "name": hardfork_name,
            "block_number": block_number,
            "timestamp": datetime.now().isoformat()
        })
        self.updated_at = datetime.now()

    def activate_fork(self):
        """Activate the fork"""
        self.status = ForkStatus.ACTIVE
        self.updated_at = datetime.now()

    def suspend_fork(self):
        """Suspend the fork"""
        self.status = ForkStatus.SUSPENDED
        self.updated_at = datetime.now()

    def deprecate_fork(self):
        """Deprecate the fork"""
        self.status = ForkStatus.DEPRECATED
        self.updated_at = datetime.now()

    def add_discussion(self, discussion: str):
        """Add community discussion"""
        self.community["discussions"].append({
            "content": discussion,
            "timestamp": datetime.now().isoformat()
        })
        self.updated_at = datetime.now()

    def update_network_params(self, params: Dict):
        """Update network parameters"""
        self.network_params.update(params)
        self.updated_at = datetime.now()

    def get_fork_info(self) -> Dict:
        """Get comprehensive fork information"""
        return {
            "fork_id": self.fork_id,
            "name": self.name,
            "status": self.status.value,
            "description": self.description,
            "created_at": self.created_at.isoformat(),
            "updated_at": self.updated_at.isoformat(),
            "consensus_type": self.consensus_type.value,
            "network_params": self.network_params,
            "developers": list(self.developers),
            "sponsors": self.sponsors,
            "benefits": self.benefits,
            "risks": self.risks,
            "community": self.community
        }

class GroundZeroNetworkManager:
    """Manager for Ground Zero Ethereum network and ecosystem"""
    
    def __init__(self):
        self.forks: Dict[str, GroundZeroFork] = {}
        self.fork_addresses: Dict[str, str] = {}  # fork_id -> blockchain_address
        self.fork_statistics: Dict[str, Dict] = {}
        self.community_events: List[Dict] = []

    def create_fork(self, name: str, description: str, 
                   consensus_type: ConsensusType = ConsensusType.POS) -> GroundZeroFork:
        """Create a new Ground Zero fork"""
        fork = GroundZeroFork(name, description)
        fork.set_consensus(consensus_type)
        
        # Generate blockchain address for this fork
        fork_address = hashlib.sha256(fork.fork_id.encode()).hexdigest()[:40]
        fork_address = f"0x{fork_address}"
        
        self.forks[fork.fork_id] = fork
        self.fork_addresses[fork.fork_id] = fork_address
        
        # Initialize statistics
        self.fork_statistics[fork.fork_id] = {
            "transactions": 0,
            "blocks": 0,
            "gas_used": 0,
            "active_accounts": 0
        }
        
        return fork

    def get_fork(self, fork_id: str) -> Optional[GroundZeroFork]:
        """Get a specific fork by ID"""
        return self.forks.get(fork_id)

    def list_forks(self) -> List[Dict]:
        """List all forks"""
        return [
            {
                "id": fork_id,
                "name": fork.name,
                "status": fork.status.value,
                "consensus": fork.consensus_type.value,
                "address": self.fork_addresses.get(fork_id)
            }
            for fork_id, fork in self.forks.items()
        ]

    def get_active_forks(self) -> List[GroundZeroFork]:
        """Get all active forks"""
        return [fork for fork in self.forks.values() if fork.status == ForkStatus.ACTIVE]

    def track_transaction(self, fork_id: str):
        """Track transaction on a fork"""
        if fork_id in self.fork_statistics:
            self.fork_statistics[fork_id]["transactions"] += 1
            self.fork_statistics[fork_id]["blocks"] += 1

    def add_community_event(self, event_name: str, description: str, 
                          date_time: datetime, participants: List[str]):
        """Add a community event"""
        event = {
            "id": str(uuid.uuid4()),
            "name": event_name,
            "description": description,
            "datetime": date_time.isoformat(),
            "participants": participants
        }
        self.community_events.append(event)
        return event

    def get_fork_stats(self, fork_id: str) -> Optional[Dict]:
        """Get statistics for a specific fork"""
        return self.fork_statistics.get(fork_id)

    def get_network_overview(self) -> Dict:
        """Get overall network overview"""
        active_forks = len(self.get_active_forks())
        total_forks = len(self.forks)
        
        return {
            "total_forks": total_forks,
            "active_forks": active_forks,
            "forks": self.list_forks(),
            "community_events": len(self.community_events)
        }

